{
    "name": "wezlo/filament-search-spotlight",
    "description": "Full-screen Spotlight / command-palette style search overlay for Filament panels. Aggregates records, pages, and custom actions with keyboard navigation and a preview pane.",
    "keywords": ["laravel", "filament", "search", "spotlight", "command-palette"],
    "license": "MIT",
    "version": "1.0.0",
    "type": "library",
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0 || ^5.0",
        "spatie/laravel-package-tools": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-livewire": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Wezlo\\FilamentSearchSpotlight\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wezlo\\FilamentSearchSpotlight\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wezlo\\FilamentSearchSpotlight\\FilamentSearchSpotlightServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
